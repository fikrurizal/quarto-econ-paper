{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(quarto render:*)",
      "Bash(quarto add:*)",
      "Bash(quarto install:*)",
      "Bash(quarto use:*)",
      "Bash(quarto --version)",
      "Bash(quarto help:*)",
      "Bash(Rscript:*)",
      "Bash(R --quiet:*)",
      "Bash(R --version)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh repo view:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(wc:*)"
    ]
  }
}
